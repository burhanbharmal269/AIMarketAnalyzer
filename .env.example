# ── NewsAPI (optional — injects live headlines into AI trade analysis) ────────
# Free key at https://newsapi.org/register (100 req/day free tier)
NEWS_API_KEY=

# ── Azure OpenAI (takes priority when all three fields below are filled) ──────
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2025-01-01-preview

# ── Standard OpenAI (used only if Azure fields above are empty) ───────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# ── Telegram alerts ───────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Scheduler (set true once Telegram is working) ─────────────────────────────
ENABLE_SCHEDULER=false
